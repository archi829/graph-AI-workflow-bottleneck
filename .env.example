# =============================================================================
# LLM MODE -- pick one. If you leave everything below blank/commented out,
# the repo runs in OFFLINE mode automatically: no LLM, no API key, no
# network calls, fully deterministic. Good for testing the pipeline with
# zero setup. See agents/offline.py.
# =============================================================================

# Uncomment to force a specific mode instead of relying on auto-detection:
# LLM_MODE=offline   # no LLM at all -- default if nothing else below is set
# LLM_MODE=ollama    # free local LLM via Ollama
# LLM_MODE=cloud     # any OpenAI-compatible paid/free-tier API

# --- Mode: ollama (free, local, no API key) ---------------------------------
# Install Ollama, then `ollama pull llama3.2:3b` (or qwen2.5:7b / llama3.1:8b
# if your machine can handle it). No key needed -- CrewAI auto-fills a dummy
# one and defaults the endpoint to http://localhost:11434.
# LLM_MODEL=ollama/llama3.2:3b
# LLM_BASE_URL=http://localhost:11434/v1   # only needed if Ollama runs elsewhere
# LLM_API_KEY=ollama                       # placeholder, Ollama ignores it

# --- Mode: cloud (needs a real key -- Groq has a free tier, OpenAI doesn't) --
# LLM_MODEL=groq/llama-3.1-70b-versatile
# LLM_API_KEY=your_groq_api_key_here
# LLM_BASE_URL=https://api.groq.com/openai/v1

# (Back-compat: OPENAI_MODEL / OPENAI_API_KEY / OPENAI_API_BASE still work
#  if you already set those -- LLM_* just takes priority when both are set.)

# --- Langfuse (optional -- only needed if you want trace visualization) -----
# Leave this whole section commented out and the app still runs fine; traces
# just won't be exported anywhere. Langfuse Cloud has a free tier if you
# want this later: https://cloud.langfuse.com
# LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
# LANGFUSE_SECRET_KEY=your_langfuse_secret_key

# --- Failure injection toggles -- Appendix B (set per-batch, not globally) --
# FAIL_RETRIEVAL_PROB=0.3
# FORCE_LOOP=true
# FORCE_TIMEOUT=true
# HALLUCINATION_RATE=0.2
# CONTEXT_OVERFLOW=true

LLM_MODE="ollama"
LLM_MODEL="phi3:mini"
LLM_BASE_URL=http://172.27.144.1:11434
LANGFUSE_SECRET_KEY=""
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_BASE_URL="https://us.cloud.langfuse.com"
LANGFUSE_HOST=https://cloud.langfuse.com